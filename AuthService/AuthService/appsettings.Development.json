{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Client": {
    "Url": "http://localhost:3000"
  },
  "Jwt": {
    "Issuer": "taxi-auth-service",
    "Audience": "taxi-client",
    "SecretKey": "dev-super-secret-key-dev-super-secret-key",
    "ExpirationMinutes": 15
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "UserTopic": "user",
    "UserRegisteredEvent": "registered",
    "GroupId": "auth-service-group",
    "MessageTimeoutMs": 5000,
    "RequestTimeoutMs": 5000
  },
  "ConnectionStrings": {
    "PostgresConnectionString": "Host=localhost;Port=5432;Username=postgres;Password=postgres;database=taxi-auth-db",
    "RedisConnectionString": "localhost:6379"
  }
}
